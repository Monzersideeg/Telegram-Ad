# ===== Telegram =====
# From @BotFather. NEVER expose to the frontend.
BOT_TOKEN=123456:ABC-DEF_your_bot_token_here
# Your Mini App frontend URL (used for CORS + referral links)
FRONTEND_URL=https://your-app.vercel.app
# Public bot username, used to build referral deep links (no @)
BOT_USERNAME=YourEarnBot

# ===== Database (Supabase Postgres) / Cache =====
# Supabase Dashboard → Project Settings → Database → Connection string.
# Use the Transaction pooler (port 6543); replace [YOUR-DATABASE-PASSWORD].
DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-DATABASE-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
# SSL auto-enables for Supabase URLs. Set false for a local Docker Postgres (no TLS):
# DATABASE_SSL=false
REDIS_URL=redis://localhost:6379

# ===== Monetag =====
# Shared secret embedded in the postback URL; Monetag echoes it back so the backend
# can authenticate the S2S callback. Use a long random string.
MONETAG_POSTBACK_SECRET=change-me-long-random-string
# Your Rewarded Interstitial MAIN zone id from the Monetag dashboard.
MONETAG_ZONE_ID=0000000
# Postback query-param names. These MUST match the postback URL template you configure
# in the Monetag SSP (per zone). Recommended template (Monetag fills the {macros}):
#   https://YOURDOMAIN/api/postback/monetag?secret=<this-secret>
#     &ymid={ymid}&event={event_type}&value={reward_event_type}
#     &price={estimated_price}&telegram_id={telegram_id}
#     &zone={zone_id}&sub={sub_zone_id}&source={request_var}
# Coins are credited ONLY for valued (paid) events; not_valued/non_valued are recorded
# but not paid, protecting your margins.
MONETAG_PARAM_SESSION=ymid
MONETAG_PARAM_VALUE=value
MONETAG_PARAM_PRICE=price
MONETAG_PARAM_TELEGRAM_ID=telegram_id
MONETAG_PARAM_EVENT=event

# ===== Economy (tune against your real eCPM before launch!) =====
# Coins credited per confirmed ad view
REWARD_PER_AD=10
# Cooldown between rewarded ads per user (seconds)
AD_COOLDOWN_SECONDS=45
# Max rewarded ads credited per user per day
MAX_ADS_PER_DAY=40
# Referral bonus = this % of a referred user's ad rewards (capped per day per referrer)
REFERRAL_BONUS_PCT=10
# Daily cap (coins) a single referrer can earn from referral bonuses
REFERRAL_DAILY_CAP=500
# Minimum balance required to request a withdrawal
MIN_WITHDRAWAL=1000
# Coin -> currency conversion for display only (e.g. 1000 coins = $1)
COINS_PER_USD=1000
# --- Game features (all rewards in coins) ---
CHECKIN_REWARD=25
CHECKIN_STREAK_STEP=5
MISSION_JOIN_TELEGRAM_REWARD=100
MISSION_WATCH10_REWARD=150
MISSION_INVITE3_REWARD=300
SPIN_COOLDOWN_SECONDS=86400

# ===== Admin =====
# Comma-separated telegram user ids allowed to use /api/admin/*
ADMIN_TELEGRAM_IDS=111111111
# Secret to sign admin session cookies (random string)
ADMIN_SECRET=change-me-admin-secret

# ===== Server =====
PORT=8787
NODE_ENV=development
