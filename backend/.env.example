# ── Telegram ──
# From @BotFather. NEVER commit the real token (this file is a template).
BOT_TOKEN=123456:ABC-your-bot-token
# Your deployed HTTPS Mini App URL (Telegram requires HTTPS).
FRONTEND_URL=https://your-app.vercel.app
BOT_USERNAME=AcEarn_bot

# ── Database (Supabase Postgres) / Cache ──
# Supabase → Project Settings → Database → Connection string (Transaction pooler, 6543).
DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-DATABASE-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
# SSL auto-enables for Supabase URLs; set false for a local Docker Postgres.
# DATABASE_SSL=false
REDIS_URL=redis://localhost:6379

# ── Monetag ──
# Long random secret embedded in the postback URL (Monetag echoes it back).
MONETAG_POSTBACK_SECRET=change-me-long-random-string
# Your Rewarded Interstitial zone id.
MONETAG_ZONE_ID=3415700
# Postback param names (match the URL template in docs/SETUP-MONETAG.md). Defaults shown.
MONETAG_PARAM_SESSION=ymid
MONETAG_PARAM_VALUE=value
MONETAG_PARAM_PRICE=price
MONETAG_PARAM_TELEGRAM_ID=telegram_id
MONETAG_PARAM_EVENT=event

# ── Economy (rewards in coins; COINS_PER_USD coins = $1) ──
REWARD_PER_AD=10
AD_COOLDOWN_SECONDS=45
MAX_ADS_PER_DAY=40
REFERRAL_BONUS_PCT=10
REFERRAL_DAILY_CAP=500
MIN_WITHDRAWAL=1000
COINS_PER_USD=1000
# Game features
CHECKIN_REWARD=25
CHECKIN_STREAK_STEP=5
MISSION_JOIN_TELEGRAM_REWARD=100
MISSION_WATCH10_REWARD=150
MISSION_INVITE3_REWARD=300
SPIN_COOLDOWN_SECONDS=86400

# ── Admin ──
# Your numeric Telegram user id(s), comma-separated.
ADMIN_TELEGRAM_IDS=
ADMIN_SECRET=change-me-admin-secret

# ── Server ──
PORT=8787
NODE_ENV=development
